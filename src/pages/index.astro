---
import rawData from '../assets/data.json';
import '../styles/global.css';
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>StarPage</title>
  </head>
  <body>
    <main class="mx-auto flex h-screen w-full max-w-[1440px] flex-col gap-4 overflow-hidden p-4 lg:p-6">
      <section class="rounded-box border border-base-content/15 bg-base-100/95 p-3 shadow-md shadow-base-300/35">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-center">
          <div class="flex shrink-0 items-center gap-2 text-xl font-bold tracking-tight text-base-content">
            <span class="inline-flex h-7 w-7 items-center justify-center rounded-md border border-primary/45 bg-primary/20 text-primary-content">
              <svg viewBox="0 0 16 16" class="h-4 w-4" fill="currentColor" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.88 3.81 4.204.611a.75.75 0 0 1 .416 1.279l-3.042 2.966.718 4.187a.75.75 0 0 1-1.088.79L8 12.347l-3.761 1.978a.75.75 0 0 1-1.088-.79l.718-4.187L.827 6.368a.75.75 0 0 1 .416-1.279l4.204-.611 1.88-3.81A.75.75 0 0 1 8 .25Z"></path></svg>
            </span>
            <span>StarPage</span>
          </div>

          <label class="input input-bordered flex w-full min-w-0 items-center gap-2 border-base-content/35 bg-base-200 shadow-sm transition-colors hover:border-base-content/45 focus-within:border-primary/65 focus-within:bg-base-100 lg:flex-1">
            <input id="search" type="text" class="w-full min-w-0 text-base-content placeholder:text-base-content/65" placeholder="搜索仓库名、描述、topic、tag" />
          </label>

          <div class="flex w-full flex-wrap items-center gap-2 lg:w-auto lg:justify-end">
            <label class="relative flex-1 min-w-[8rem] sm:flex-none sm:w-36">
              <span class="pointer-events-none absolute inset-y-0 left-2 z-10 flex items-center text-base-content/85">
                <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="currentColor" aria-hidden="true"><path d="M6.75 1.5a.75.75 0 0 1 .75.75v7.19l1.97-1.97a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0l-3.25-3.25a.75.75 0 1 1 1.06-1.06L6 9.44V2.25a.75.75 0 0 1 .75-.75Zm6.5 11.25a.75.75 0 0 1 0 1.5h-9a.75.75 0 0 1 0-1.5h9Z"></path></svg>
              </span>
              <select id="sort" class="select select-bordered select-sm relative z-0 w-full border-base-content/30 bg-base-200 pl-7 pr-6 text-base-content hover:border-base-content/45 focus:border-primary/60">
                <option value="updated_desc">最近更新</option>
                <option value="stars_desc">Star 数量</option>
                <option value="forks_desc">Fork 数量</option>
                <option value="name_asc">名称 A-Z</option>
              </select>
            </label>

            <label class="relative flex-1 min-w-[8rem] sm:flex-none sm:w-36">
              <span class="pointer-events-none absolute inset-y-0 left-2 z-10 flex items-center text-base-content/85">
                <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" aria-hidden="true" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M2.25 3h11.5l-4.5 5.1V12l-2.5 1V8.1L2.25 3Z"></path></svg>
              </span>
              <select id="topic-filter" class="select select-bordered select-sm relative z-0 w-full border-base-content/30 bg-base-200 pl-7 pr-6 text-base-content hover:border-base-content/45 focus:border-primary/60">
                <option value="all">全部 Topic</option>
              </select>
            </label>

            <button id="theme-toggle" class="btn btn-sm border border-base-content/35 bg-base-200 text-base-content hover:border-base-content/55 hover:bg-base-100" type="button" aria-pressed="false" title="切换主题">
              <span aria-hidden="true">夜</span>
              <span>深色</span>
            </button>
            <button id="auth-btn" class="btn btn-sm border border-primary/60 bg-primary/30 text-base-content hover:border-primary hover:bg-primary/40">Owner 授权</button>
            <button id="logout-btn" class="btn btn-error btn-sm" style="display:none">退出</button>
          </div>
        </div>
      </section>

      <div class="rounded-box border border-base-content/15 bg-base-200/75 px-3 py-2 text-sm text-base-content/85" id="auth-status">未授权：只读模式</div>
      <div id="device-flow" class="alert rounded-box border border-dashed border-base-content/30 bg-base-100/90 text-sm text-base-content/90" style="display:none"></div>

      <section class="grid min-h-0 flex-1 gap-4 lg:grid-cols-[1fr_3fr]">
        <aside class="flex h-full min-h-0 flex-col gap-4">
          <section class="card flex min-h-0 flex-1 border border-base-content/15 bg-base-100/90 shadow-md shadow-base-300/30">
            <div class="card-body flex min-h-0 flex-col gap-2 p-4">
              <h3 class="card-title text-base text-base-content">Tags</h3>
              <div id="tags" class="flex min-h-0 flex-1 flex-wrap content-start items-start gap-1.5 overflow-y-auto pr-1"></div>
            </div>
          </section>

          <section class="card flex min-h-0 flex-1 border border-base-content/15 bg-base-100/90 shadow-md shadow-base-300/30">
            <div class="card-body flex min-h-0 flex-col gap-2 p-4">
              <h3 class="card-title text-base text-base-content">Topics</h3>
              <div id="topics" class="flex min-h-0 flex-1 flex-wrap content-start items-start gap-1.5 overflow-y-auto pr-1"></div>
            </div>
          </section>
        </aside>

        <section id="cards" class="min-h-0 overflow-y-auto pr-1">
          <div id="cards-grid" class="columns-1 gap-2 sm:columns-2 xl:columns-3 2xl:columns-4"></div>
        </section>
      </section>
    </main>

    <script id="initial-data" type="application/json" is:inline set:html={JSON.stringify(rawData)}></script>
    <script src="../scripts/app.ts"></script>
  </body>
</html>
